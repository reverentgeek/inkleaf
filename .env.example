# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/inkleaf?retryWrites=true&w=majority

# Database name (optional, default inkleaf)
# MONGODB_DB=inkleaf

# OpenAI API key (required for Vector Search / embeddings)
OPENAI_API_KEY=sk-...

# Backend port (optional, default 3001)
PORT=3001

# Local SQLite store for offline support (optional, default backend/data/inkleaf.db)
# SQLITE_PATH=/path/to/inkleaf.db

# Background sync interval in ms (optional, default 15000)
# SYNC_INTERVAL_MS=15000
